{
  "name": "bills-management-root",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "frontend:dev": "npm run dev -w frontend",
    "backend:dev": "npm run dev -w backend",
    "dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\"",
    "install:all": "npm install && npm install -w frontend && npm install -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
