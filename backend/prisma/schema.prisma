generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  passwordHash    String         @map("password_hash")
  name            String
  role            Role           @default(viewer)
  preferences     Json?          @default("{}")
  subscriptions   Subscription[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  admin
  finance
  viewer
}

model Subscription {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceName    String         @map("service_name")
  category       String         @map("category") @default("General")
  period         BillingPeriod
  priceINR       Decimal        @db.Decimal(10, 2) @map("price_inr")
  priceAED       Decimal        @db.Decimal(10, 2) @map("price_aed")
  totalYearly    Decimal?       @db.Decimal(10, 2) @map("total_yearly") // Can be computed or stored
  validityDate   DateTime       @map("validity_date")
  paymentMethod  String         @map("payment_method")
  cardLast4      String?        @map("card_last4")
  bankName       String         @map("bank_name")
  region         Region
  status         SubscriptionStatus @default(active)
  notes          String?        @db.Text
  notifications  Notification[]
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([userId])
  @@index([validityDate])
  @@index([status])
  @@map("subscriptions")
}

enum BillingPeriod {
  monthly
  quarterly
  yearly
}

enum Region {
  India
  UAE
}

enum SubscriptionStatus {
  active
  cancelled
  paused
}

model Notification {
  id             String           @id @default(uuid())
  userId         String           @map("user_id")
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String?          @map("subscription_id")
  subscription   Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  type           NotificationType
  message        String           @db.Text
  isRead         Boolean          @default(false) @map("is_read")
  sentAt         DateTime         @default(now()) @map("sent_at")
  emailSent      Boolean          @default(false) @map("email_sent")

  @@index([userId])
  @@index([isRead])
  @@index([sentAt])
  @@map("notifications")
}

enum NotificationType {
  upcoming_bill
  overdue
  payment_confirmation
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String   @db.VarChar(50)
  tableName   String   @map("table_name") @db.VarChar(50)
  recordId    String   @map("record_id")
  oldData     Json?    @map("old_data")
  newData     Json?    @map("new_data")
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
